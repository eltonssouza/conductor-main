# Honcho self-host — environment.
#
# The reasoning provider (deriver + dialectic + summary) is YOUR choice — it is
# not pre-selected. Either:
#   a) run `python -m cdt.honcho_setup` to generate .env for a provider, or
#   b) copy this file to .env and uncomment ONE preset below, then add your key.
#
# Any OpenAI-compatible endpoint works (OpenAI, DeepSeek, OpenRouter, Together,
# Fireworks, local Ollama/vLLM…), plus native Anthropic.

# === API key (name depends on the transport) ===============================
# OpenAI-compatible providers use LLM_OPENAI_API_KEY; Anthropic uses
# LLM_ANTHROPIC_API_KEY. Set the one your chosen preset needs.
LLM_OPENAI_API_KEY=set-your-key
# LLM_ANTHROPIC_API_KEY=set-your-key

# === Choose ONE preset (uncomment all three feature blocks for it) =========

# --- OpenAI ---
# DERIVER_MODEL_CONFIG__TRANSPORT=openai
# DERIVER_MODEL_CONFIG__MODEL=gpt-4o-mini
# DERIVER_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.openai.com/v1
# DIALECTIC_MODEL_CONFIG__TRANSPORT=openai
# DIALECTIC_MODEL_CONFIG__MODEL=gpt-4o-mini
# DIALECTIC_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.openai.com/v1
# SUMMARY_MODEL_CONFIG__TRANSPORT=openai
# SUMMARY_MODEL_CONFIG__MODEL=gpt-4o-mini
# SUMMARY_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.openai.com/v1

# --- DeepSeek ---
# DERIVER_MODEL_CONFIG__TRANSPORT=openai
# DERIVER_MODEL_CONFIG__MODEL=deepseek-chat
# DERIVER_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.deepseek.com/v1
# DIALECTIC_MODEL_CONFIG__TRANSPORT=openai
# DIALECTIC_MODEL_CONFIG__MODEL=deepseek-chat
# DIALECTIC_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.deepseek.com/v1
# SUMMARY_MODEL_CONFIG__TRANSPORT=openai
# SUMMARY_MODEL_CONFIG__MODEL=deepseek-chat
# SUMMARY_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.deepseek.com/v1

# --- Local Ollama (no key; reaches the host from the container) ---
# DERIVER_MODEL_CONFIG__TRANSPORT=openai
# DERIVER_MODEL_CONFIG__MODEL=llama3.1
# DERIVER_MODEL_CONFIG__OVERRIDES__BASE_URL=http://host.docker.internal:11434/v1
# DIALECTIC_MODEL_CONFIG__TRANSPORT=openai
# DIALECTIC_MODEL_CONFIG__MODEL=llama3.1
# DIALECTIC_MODEL_CONFIG__OVERRIDES__BASE_URL=http://host.docker.internal:11434/v1
# SUMMARY_MODEL_CONFIG__TRANSPORT=openai
# SUMMARY_MODEL_CONFIG__MODEL=llama3.1
# SUMMARY_MODEL_CONFIG__OVERRIDES__BASE_URL=http://host.docker.internal:11434/v1

# --- Anthropic (native transport; no base URL) ---
# DERIVER_MODEL_CONFIG__TRANSPORT=anthropic
# DERIVER_MODEL_CONFIG__MODEL=claude-haiku-4-5
# DIALECTIC_MODEL_CONFIG__TRANSPORT=anthropic
# DIALECTIC_MODEL_CONFIG__MODEL=claude-haiku-4-5
# SUMMARY_MODEL_CONFIG__TRANSPORT=anthropic
# SUMMARY_MODEL_CONFIG__MODEL=claude-haiku-4-5

# Self-host: no auth (the API binds to localhost only in the compose).
AUTH_USE_AUTH=false
