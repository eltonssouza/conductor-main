# Honcho self-host — environment (copy to .env and fill the key).
# Background reasoning (deriver + dialectic + summary) runs on DeepSeek via its
# OpenAI-compatible API. Get a key at https://platform.deepseek.com/.

# DeepSeek API key (used as the OpenAI-compatible credential).
LLM_OPENAI_API_KEY=sk-your-deepseek-key

# Deriver (extracts insights from each message in the background).
DERIVER_MODEL_CONFIG__TRANSPORT=openai
DERIVER_MODEL_CONFIG__MODEL=deepseek-chat
DERIVER_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.deepseek.com/v1

# Dialectic (answers `recall` / peer.chat queries by reasoning over memory).
DIALECTIC_MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_MODEL_CONFIG__MODEL=deepseek-chat
DIALECTIC_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.deepseek.com/v1

# Summary (compacts long sessions into prompt-ready context).
SUMMARY_MODEL_CONFIG__TRANSPORT=openai
SUMMARY_MODEL_CONFIG__MODEL=deepseek-chat
SUMMARY_MODEL_CONFIG__OVERRIDES__BASE_URL=https://api.deepseek.com/v1

# Self-host: no auth (the API is bound to localhost only in the compose).
AUTH_USE_AUTH=false
